# MCP Tool Hub — Environment Configuration
# Copy this to .env and adjust for your environment.
# For Ansible deployment, these become variables in your playbook.

# ── Directory where all hub data is stored ──────────────────────
MCP_DATA_DIR=/opt/mcp-tool-hub/data

# ── Filesystem Server ────────────────────────────────────────────
# The ONLY directory the AI can read/write. Everything else is blocked.
MCP_FS_ROOT=/opt/mcp-tool-hub/data/files

# ── Git Server ───────────────────────────────────────────────────
# Base directory containing git repositories
MCP_GIT_WORKSPACE=/opt/mcp-tool-hub/data/repos

# ── Memory Server ────────────────────────────────────────────────
# Path to the persistent memory JSON file
MCP_MEMORY_PATH=/opt/mcp-tool-hub/data/memory.json

# ── Fetch Server ─────────────────────────────────────────────────
# Comma-separated list of allowed domains (empty = allow all)
# Example: MCP_FETCH_ALLOWED_DOMAINS=github.com,api.example.com
MCP_FETCH_ALLOWED_DOMAINS=

# ── Logging ──────────────────────────────────────────────────────
# debug | info | warn | error
MCP_LOG_LEVEL=info
